# Ignore node_modules, as they will be installed in the Docker image
node_modules

# Ignore the build output directory
dist

# Ignore Vite / build artifacts
build

# Ignore editor/project configs
.vscode
.idea

# Ignore env files (keeps secrets out of images)
.env
.env.*

# Ignore git files
.git
.gitignore

# Ignore Docker files
Dockerfile
.dockerignore
docker-compose.yml

# Ignore local development files
.env.local
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Optional cache folders
.cache
.parcel-cache
.nyc_output
.turbo
